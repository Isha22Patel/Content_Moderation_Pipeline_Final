# Groq API key — required for LLM classification
# Get one free at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# SQLite connection string — required for Prisma
# Local development (SQLite): file:./prisma/dev.db
DATABASE_URL="file:./prisma/dev.db"

# Optional: override the default classification model
# Defaults to llama-3.3-70b-versatile
# MODERATION_MODEL=llama-3.3-70b-versatile
